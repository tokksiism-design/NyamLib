    -- ==================== IMAGE GRID (карточки с фото) ====================
    function TabClass:ImageGrid(images, opts)
        -- images = { {Url="...", Text="Title", Callback=fn}, ... }
        opts = opts or {}
        local columns = opts.Columns or 3
        local cardH = opts.CardHeight or 100
        local imgH = cardH - 24

        self._lastRow = nil

        local rows = _mceil(#images / columns)
        local totalH = rows * (cardH + 6)

        local gridFrame = Instance.new("Frame")
        gridFrame.Size = UDim2.new(1, 0, 0, totalH)
        gridFrame.BackgroundTransparency = 1
        gridFrame.Parent = self.Container
        storeOrigSize(gridFrame, 1)

        local grid = Instance.new("UIGridLayout")
        grid.CellPadding = UDim2.fromOffset(6, 6)
        grid.CellSize = UDim2.new(1 / columns, -(6 * (columns - 1) / columns), 0, cardH)
        grid.SortOrder = Enum.SortOrder.LayoutOrder
        grid.Parent = gridFrame

        for _, imgData in _ipairs(images) do
            local card = Instance.new("Frame")
            card.BackgroundColor3 = THEME.ContainerColor
            card.BorderSizePixel = 0
            card.ClipsDescendants = true
            card.Parent = gridFrame
            Instance.new("UICorner", card).CornerRadius = UDim.new(0, 8)

            local imageLabel = Instance.new("ImageLabel")
            imageLabel.Size = UDim2.new(1, -4, 0, imgH - 4)
            imageLabel.Position = UDim2.new(0, 2, 0, 2)
            imageLabel.BackgroundTransparency = 1
            imageLabel.ScaleType = Enum.ScaleType.Crop
            imageLabel.Parent = card
            Instance.new("UICorner", imageLabel).CornerRadius = UDim.new(0, 6)

            -- Load image
            if imgData.Url then
                imageLabel.ImageTransparency = 1
                _spawn(function()
                    local asset = fetchImage(imgData.Url)
                    if asset then
                        imageLabel.Image = asset
                        createTween(imageLabel, T_FAST, { ImageTransparency = 0 })
                    end
                end)
            elseif imgData.Asset then
                imageLabel.Image = imgData.Asset
            end

            local textLabel = Instance.new("TextLabel")
            textLabel.Size = UDim2.new(1, -8, 0, 22)
            textLabel.Position = UDim2.new(0, 4, 1, -23)
            textLabel.BackgroundTransparency = 1
            textLabel.Text = imgData.Text or ""
            textLabel.TextColor3 = THEME.TextColor
            textLabel.TextSize = 10
            textLabel.Font = THEME.Font
            textLabel.TextTruncate = Enum.TextTruncate.AtEnd
            textLabel.TextXAlignment = Enum.TextXAlignment.Left
            textLabel.Parent = card

            if imgData.Callback then
                local btn = Instance.new("TextButton")
                btn.Size = UDim2.fromScale(1, 1)
                btn.BackgroundTransparency = 1
                btn.Text = ""
                btn.Parent = card
                attachPressEffect(btn, 1.03)
                btn.Activated:Connect(function()
                    _spawn(wrapCallback(imgData.Callback))
                end)
            end

            -- Hover
            card.MouseEnter:Connect(function()
                createTween(card, T_FAST, { BackgroundColor3 = THEME.DividerColor })
            end)
            card.MouseLeave:Connect(function()
                createTween(card, T_FAST, { BackgroundColor3 = THEME.ContainerColor })
            end)
        end

        return gridFrame
    end

