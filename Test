local HAS_FS = _typeof(writefile) == "function" and _typeof(readfile) == "function" and _typeof(isfile) == "function"
local CACHE_FOLDER = "ios_lib_cache"

if HAS_FS and _typeof(makefolder) == "function" and _typeof(isfolder) == "function" then
    _pcall(function()
        if not isfolder(CACHE_FOLDER) then makefolder(CACHE_FOLDER) end
    end)
