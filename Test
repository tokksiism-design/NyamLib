local function serializeValue(v)
    local t = _typeof(v)
    if t == "Vector3" then return { __t = "v3", d = { v.X, v.Y, v.Z } }
    elseif t == "Vector2" then return { __t = "v2", d = { v.X, v.Y } }
    elseif t == "CFrame" then return { __t = "cf", d = { v:GetComponents() } }
    elseif t == "Color3" then return { __t = "c3", d = { v.R, v.G, v.B } }
    elseif t == "UDim2" then return { __t = "u2", d = { v.X.Scale, v.X.Offset, v.Y.Scale, v.Y.Offset } }
    elseif t == "table" then
        local out = { __t = "tbl", d = {} }
        for key, val in _pairs(v) do out.d[_tostring(key)] = serializeValue(val) end
        return out
    else return { __t = "raw", d = v } end
end

local function deserializeValue(v)
    if _typeof(v) ~= "table" or v.__t == nil then return v end
    local t, d = v.__t, v.d
    if t == "v3" then return Vector3.new(d[1], d[2], d[3])
    elseif t == "v2" then return Vector2.new(d[1], d[2])
    elseif t == "cf" then return CFrame.new(_unpack(d))
    elseif t == "c3" then return Color3.new(d[1], d[2], d[3])
    elseif t == "u2" then return UDim2.new(d[1], d[2], d[3], d[4])
    elseif t == "tbl" then
        local out = {}
        for key, val in _pairs(d) do
            local numKey = _tonumber(key)
            out[numKey or key] = deserializeValue(val)
        end
        return out
    else return d end
end

function iOSLibrary.CreateCache(name)
    local self = _setmetatable({}, CacheClass)
    self.Name = name
    self.FilePath = CACHE_FOLDER .. "/" .. name .. ".json"
    self.Data = {}
    self._saveQueued = false
    self:Load()
    return self
end

function CacheClass:Load()
    if not HAS_FS then return end
    local ok, result = _pcall(function()
        if isfile(self.FilePath) then
            local raw = readfile(self.FilePath)
            local decoded = HttpService:JSONDecode(raw)
            local out = {}
            for k, v in _pairs(decoded) do out[k] = deserializeValue(v) end
            return out
        end
    end)
    if ok and result then self.Data = result end
end

function CacheClass:Save()
    if not HAS_FS then return end
    _pcall(function()
        local out = {}
        for k, v in _pairs(self.Data) do out[k] = serializeValue(v) end
        writefile(self.FilePath, HttpService:JSONEncode(out))
    end)
end

function CacheClass:Set(key, value)
    self.Data[key] = value
    if not self._saveQueued then
        self._saveQueued = true
        _delay(0.5, function()
            self._saveQueued = false
            self:Save()
        end)
    end
end

function CacheClass:Get(key, default)
    local v = self.Data[key]
    if v == nil then return default end
    return v
end

function CacheClass:Clear()
    self.Data = {}
    self:Save()
end

