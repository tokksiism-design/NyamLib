local BezierEngine = {}
do
    local Presets = {
        Linear       = {0, 0, 1, 1},
        EaseIn       = {0.42, 0, 1, 1},
        EaseOut      = {0, 0, 0.58, 1},
        EaseInOut    = {0.42, 0, 0.58, 1},
        EaseOutBack  = {0.175, 0.885, 0.32, 1.275},
        EaseInBack   = {0.6, -0.28, 0.735, 0.045},
        EaseInOutBack= {0.68, -0.55, 0.265, 1.55},
        EaseOutCirc  = {0.075, 0.82, 0.165, 1},
        EaseInCirc   = {0.6, 0.04, 0.98, 0.335},
        EaseOutExpo  = {0.19, 1, 0.22, 1},
        EaseInExpo   = {0.95, 0.05, 0.795, 0.035},
        Bounce       = {0.175, 0.885, 0.32, 1.175},
        Spring       = {0.155, 1.105, 0.295, 1.12},
        Smooth       = {0.25, 0.1, 0.25, 1},
        Snappy       = {0.17, 0.89, 0.32, 1.28},
        iOSDefault   = {0.25, 0.1, 0.25, 1},
        iOSSpring    = {0.2, 0.9, 0.3, 1.2},
    }

    local function cubicBezier(t, p0, p1, p2, p3)
        local u = 1 - t
        return u*u*u*p0 + 3*u*u*t*p1 + 3*u*t*t*p2 + t*t*t*p3
    end

    local function solveBezierX(x, x1, x2)
        local t = x
        for _ = 1, 8 do
            local cx = cubicBezier(t, 0, x1, x2, 1) - x
            if _mabs(cx) < 0.001 then break end
            local d = 3*(1-t)*(1-t)*x1 + 6*(1-t)*t*(x2-x1) + 3*t*t*(1-x2)
            if _mabs(d) < 1e-6 then break end
            t = _mclamp(t - cx/d, 0, 1)
        end
        return t
    end

    function BezierEngine.curve(x1, y1, x2, y2)
        return function(t)
            if t <= 0 then return 0 end
            if t >= 1 then return 1 end
            local st = solveBezierX(t, x1, x2)
            return cubicBezier(st, 0, y1, y2, 1)
        end
    end

    function BezierEngine.getPreset(name)
        local p = Presets[name] or Presets.iOSDefault
        return BezierEngine.curve(p[1], p[2], p[3], p[4])
    end

    function BezierEngine.getPresetNames()
        local names = {}
        for k in Presets do _tinsert(names, k) end
        _tsort(names)
        return names
    end

    -- Custom tween using Bezier curves (heartbeat-driven)
    function BezierEngine.tween(instance, properties, duration, curveName, callback)
        duration = duration or 0.3
        local easingFn = _type(curveName) == "function" and curveName or BezierEngine.getPreset(curveName or "iOSDefault")

        local startValues = {}
        for prop, _ in properties do
            _pcall(function() startValues[prop] = instance[prop] end)
        end

        local startTime = _tick()
        local conn
        conn = RunService.Heartbeat:Connect(function()
            local elapsed = _tick() - startTime
            local progress = _mclamp(elapsed / duration, 0, 1)
            local eased = easingFn(progress)

            for prop, target in properties do
                local start = startValues[prop]
                if start ~= nil then
                    _pcall(function()
                        local tv = _typeof(start)
                        if tv == "number" then
                            instance[prop] = start + (target - start) * eased
                        elseif tv == "UDim2" then
                            instance[prop] = start:Lerp(target, eased)
                        elseif tv == "Color3" then
                            instance[prop] = start:Lerp(target, eased)
                        elseif tv == "UDim" then
                            instance[prop] = UDim.new(
                                start.Scale + (target.Scale - start.Scale) * eased,
                                start.Offset + (target.Offset - start.Offset) * eased
                            )
                        elseif tv == "Vector2" then
                            instance[prop] = start:Lerp(target, eased)
                        else
                            if progress >= 1 then instance[prop] = target end
                        end
                    end)
                end
            end

            if progress >= 1 then
                conn:Disconnect()
                if callback then _spawn(callback) end
            end
        end)

        return {
            Cancel = function() conn:Disconnect() end,
            connection = conn,
        }
    end
end

