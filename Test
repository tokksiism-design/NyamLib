local function generateRandomName(length)
    length = length or _mrand(14, 28)
    local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_"
    local result = {}
    for i = 1, length do
        local idx = _mrand(1, _slen(chars))
        result[i] = _ssub(chars, idx, idx)
    end
    return _tconcat(result)
end

-- XOR string encryption
local StringCrypt = {}
do
    local _key = generateRandomName(32)
    function StringCrypt.encrypt(str)
        local out = {}
        for i = 1, _slen(str) do
            local cb = _sbyte(str, i)
            local kb = _sbyte(_key, ((i - 1) % _slen(_key)) + 1)
            out[i] = _schar(bit32.bxor(cb, kb))
        end
        return _tconcat(out)
    end
    StringCrypt.decrypt = StringCrypt.encrypt
end

