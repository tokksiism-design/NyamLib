        textLabel.TextXAlignment = Enum.TextXAlignment.Left
        textLabel.BackgroundTransparency = 1
        textLabel.Parent = itemFrame

        local preview = Instance.new("Frame")
        preview.Size = UDim2.fromOffset(22, 22)
        preview.Position = UDim2.new(1, -34, 0, (_mfloor((size.Y.Offset or 38) / 2)) - 11)
        preview.BackgroundColor3 = currentColor
        preview.BorderSizePixel = 0
        preview.Parent = itemFrame
        Instance.new("UICorner", preview).CornerRadius = UDim.new(0, 6)
        local previewStroke = Instance.new("UIStroke")
        previewStroke.Color = THEME.DividerColor
        previewStroke.Thickness = 1
        previewStroke.Parent = preview

        local baseH = size.Y.Offset or 38
        local pickerH = 90

        -- HSV sliders
        local pickerHolder = Instance.new("Frame")
        pickerHolder.Size = UDim2.new(1, -16, 0, pickerH)
        pickerHolder.Position = UDim2.new(0, 8, 0, baseH + 4)
        pickerHolder.BackgroundTransparency = 1
        pickerHolder.Visible = false
        pickerHolder.Parent = itemFrame

        local function createHSVSlider(yPos, label_text, startVal, gradient)
            local track = Instance.new("Frame")
            track.Size = UDim2.new(1, 0, 0, 12)
            track.Position = UDim2.fromOffset(0, yPos)
            track.BackgroundColor3 = Color3.new(0.3, 0.3, 0.3)
            track.BorderSizePixel = 0
            track.Parent = pickerHolder
            Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

            if gradient then
                local uiGrad = Instance.new("UIGradient")
                uiGrad.Color = gradient
                uiGrad.Parent = track
            end

            local sKnob = Instance.new("Frame")
            sKnob.Size = UDim2.fromOffset(10, 16)
            sKnob.Position = UDim2.new(startVal, 0, 0.5, 0)
            sKnob.AnchorPoint = Vector2.new(0.5, 0.5)
            sKnob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            sKnob.BorderSizePixel = 0
            sKnob.ZIndex = 5
            sKnob.Parent = track
            Instance.new("UICorner", sKnob).CornerRadius = UDim.new(0, 4)

            return track, sKnob
        end

        local hueGrad = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromHSV(0, 1, 1)),
            ColorSequenceKeypoint.new(0.167, Color3.fromHSV(0.167, 1, 1)),
            ColorSequenceKeypoint.new(0.333, Color3.fromHSV(0.333, 1, 1)),
            ColorSequenceKeypoint.new(0.5, Color3.fromHSV(0.5, 1, 1)),
            ColorSequenceKeypoint.new(0.667, Color3.fromHSV(0.667, 1, 1)),
            ColorSequenceKeypoint.new(0.833, Color3.fromHSV(0.833, 1, 1)),
            ColorSequenceKeypoint.new(1, Color3.fromHSV(1, 1, 1)),
        })

        local hueTrack, hueKnob = createHSVSlider(0, "H", hue, hueGrad)
        local satTrack, satKnob = createHSVSlider(26, "S", sat)
        local valTrack, valKnob = createHSVSlider(52, "V", val)

        local function updateColor()
            currentColor = Color3.fromHSV(_mclamp(hue, 0, 1), _mclamp(sat, 0, 1), _mclamp(val, 0, 1))
            preview.BackgroundColor3 = currentColor
            -- Update sat/val track colors for visual feedback
            satTrack.BackgroundColor3 = Color3.fromHSV(hue, 0.3, val)
            valTrack.BackgroundColor3 = Color3.fromHSV(hue, sat, 0.3)
            _spawn(callback, currentColor)
        end

        local function setupDrag(track, knob, setter)
            local dragging = false
            track.InputBegan:Connect(function(input)
                if isTouchOrMouse(input) then
                    dragging = true
                    local pct = _mclamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                    knob.Position = UDim2.new(pct, 0, 0.5, 0)
                    setter(pct)
                    updateColor()
                    watchInputEnd(input, function() dragging = false end)
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    local pct = _mclamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                    knob.Position = UDim2.new(pct, 0, 0.5, 0)
                    setter(pct)
                    updateColor()
                end
            end)
        end

        setupDrag(hueTrack, hueKnob, function(v) hue = v end)
        setupDrag(satTrack, satKnob, function(v) sat = v end)
        setupDrag(valTrack, valKnob, function(v) val = v end)

        -- Toggle
        local toggleBtn = Instance.new("TextButton")
        toggleBtn.Size = UDim2.new(1, 0, 0, baseH)
        toggleBtn.BackgroundTransparency = 1
        toggleBtn.Text = ""
        toggleBtn.Parent = itemFrame

        toggleBtn.Activated:Connect(function()
            expanded = not expanded
            if expanded then
                pickerHolder.Visible = true
                itemFrame.Size = UDim2.new(1, 0, 0, baseH + pickerH + 12)
            else
                pickerHolder.Visible = false
                itemFrame.Size = UDim2.new(1, 0, 0, baseH)
            end
        end)

        local api = {}
        function api:Set(color)
            currentColor = color
            hue, sat, val = color:ToHSV()
            preview.BackgroundColor3 = color
            hueKnob.Position = UDim2.new(hue, 0, 0.5, 0)
            satKnob.Position = UDim2.new(sat, 0, 0.5, 0)
            valKnob.Position = UDim2.new(val, 0, 0.5, 0)
        end
        function api:Get() return currentColor end
        return api
    end

