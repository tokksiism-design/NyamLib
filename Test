local WaveAnim = {}
do
    -- Wave hide: circular mask expands from a point, covering the UI
    function WaveAnim.hide(mainFrame, windowScale, originX, originY, duration, callback)
        duration = duration or 0.45

        -- Create overlay
        local overlay = Instance.new("Frame")
        overlay.Name = generateRandomName(8)
        overlay.Size = UDim2.fromScale(1, 1)
        overlay.Position = UDim2.fromScale(0, 0)
        overlay.BackgroundTransparency = 1
        overlay.ClipsDescendants = true
        overlay.ZIndex = 100
        overlay.Parent = mainFrame

        -- Expanding circle mask
        local mask = Instance.new("Frame")
        mask.Name = generateRandomName(8)
        mask.BackgroundColor3 = THEME.BgColor
        mask.BackgroundTransparency = 0
        mask.Size = UDim2.fromOffset(0, 0)
        mask.AnchorPoint = Vector2.new(0.5, 0.5)
        mask.Position = UDim2.new(originX or 0.5, 0, originY or 0, 0)
        mask.ZIndex = 101
        mask.Parent = overlay

        Instance.new("UICorner", mask).CornerRadius = UDim.new(1, 0)

        -- Calculate max size needed to cover entire frame
        local frameSize = mainFrame.AbsoluteSize
        local maxDim = _mmax(frameSize.X, frameSize.Y) * 3

        BezierEngine.tween(mask, {
            Size = UDim2.fromOffset(maxDim, maxDim),
        }, duration, "EaseInCirc", function()
            mainFrame.Visible = false
            overlay:Destroy()
            if callback then callback() end
        end)
    end

    -- Wave show: circle shrinks to reveal UI
    function WaveAnim.show(mainFrame, windowScale, originX, originY, duration, callback)
        duration = duration or 0.45
        mainFrame.Visible = true

        local overlay = Instance.new("Frame")
        overlay.Name = generateRandomName(8)
        overlay.Size = UDim2.fromScale(1, 1)
        overlay.Position = UDim2.fromScale(0, 0)
        overlay.BackgroundTransparency = 1
        overlay.ClipsDescendants = true
        overlay.ZIndex = 100
        overlay.Parent = mainFrame

        local frameSize = mainFrame.AbsoluteSize
        local maxDim = _mmax(frameSize.X, frameSize.Y) * 3

        local mask = Instance.new("Frame")
        mask.Name = generateRandomName(8)
        mask.BackgroundColor3 = THEME.BgColor
        mask.Size = UDim2.fromOffset(maxDim, maxDim)
        mask.AnchorPoint = Vector2.new(0.5, 0.5)
        mask.Position = UDim2.new(originX or 0.5, 0, originY or 0, 0)
        mask.ZIndex = 101
        mask.Parent = overlay

        Instance.new("UICorner", mask).CornerRadius = UDim.new(1, 0)

        BezierEngine.tween(mask, {
            Size = UDim2.fromOffset(0, 0),
        }, duration, "EaseOutCirc", function()
            overlay:Destroy()
            if callback then callback() end
        end)
    end
end

