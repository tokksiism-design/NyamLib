local function buildAvatar(parent, size)
    local circle = Instance.new("Frame")
    circle.Size = UDim2.new(0, size, 0, size)
    circle.BackgroundColor3 = THEME.DividerColor
    circle.Parent = parent
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

    local circleStroke = Instance.new("UIStroke")
    circleStroke.Color = THEME.DividerColor
    circleStroke.Thickness = 1
    circleStroke.Parent = circle

    local player = LocalPlayer

    local viewportOk = _pcall(function()
        local char = player.Character
        if not char then error("no char") end

        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if not humanoid then error("no humanoid") end

        -- Use HumanoidDescription for FULLY CLOTHED avatar
        local description = humanoid:GetAppliedDescription()
        local clone = Players:CreateHumanoidModelFromDescription(description, humanoid.RigType)

        -- Remove scripts/animators/sounds
        for _, obj in clone:GetDescendants() do
            if obj:IsA("BaseScript") or obj:IsA("Animator")
                or obj:IsA("Animation") or obj:IsA("Sound") then
                obj:Destroy()
            end
        end

        local hrp = clone:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.Anchored = true end

        local cloneHum = clone:FindFirstChildOfClass("Humanoid")
        if cloneHum then cloneHum:Destroy() end

        local vp = Instance.new("ViewportFrame")
        vp.Size = UDim2.new(1, 0, 1, 0)
        vp.BackgroundTransparency = 1
        vp.Parent = circle
        Instance.new("UICorner", vp).CornerRadius = UDim.new(1, 0)

        clone.Parent = vp

        local cloneHead = clone:FindFirstChild("Head")
        local cam = Instance.new("Camera")
        cam.Parent = vp
        vp.CurrentCamera = cam

        if cloneHead then
            local headPos = cloneHead.Position
            cam.CFrame = CFrame.new(headPos + cloneHead.CFrame.LookVector * 1.8, headPos)
        elseif hrp then
            cam.CFrame = CFrame.new(hrp.Position + Vector3.new(0, 1.5, 3), hrp.Position + Vector3.new(0, 1.5, 0))
        end
    end)

    if not viewportOk then
        local img = Instance.new("ImageLabel")
        img.Size = UDim2.new(1, 0, 1, 0)
        img.BackgroundTransparency = 1
        img.Parent = circle
        Instance.new("UICorner", img).CornerRadius = UDim.new(1, 0)
        local thumbOk, thumb = _pcall(function()
            return Players:GetUserThumbnailAsync(player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
        end)
        img.Image = (thumbOk and thumb)
            or ("rbxthumb://type=AvatarHeadShot&id=" .. player.UserId .. "&w=100&h=100")
    end

    return circle
end

