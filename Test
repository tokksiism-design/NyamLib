function iOSLibrary.CreateWindow(title, size, config)
    local self = _setmetatable({}, iOSLibrary)
    config = config or {}

    -- HideMethod: 1 = X button + wave up
    --             2 = Bottom line fill/drain
    --             3 = Double-tap open + tap title hide
    --             4 = Circle hamburger button
    local hideMethod = config.HideMethod or 1

    local settingsCache = iOSLibrary.CreateCache("ios_lib_settings")
    self.SettingsCache = settingsCache

    -- Load saved hide method
    hideMethod = settingsCache:Get("HideMethod", hideMethod)

    local camera = Workspace.CurrentCamera
    local viewport = camera and camera.ViewportSize or Vector2.new(800, 600)
    local desired = size or Vector2.new(470, 330)
    local windowSize = Vector2.new(
        _mmin(desired.X, viewport.X - 24),
        _mmin(desired.Y, viewport.Y - 60)
    )

    -- Init protection
    AntiSpy.init()

    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = generateRandomName(22)
    screenGui.ResetOnSpawn = false
    screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    screenGui.IgnoreGuiInset = true
    screenGui.DisplayOrder = 2147483647

    -- Parent with deep embed
    local parented = false

    -- Try deep embed first (Anti-DEX)
    parented = AntiDex.deepEmbed(screenGui)

    if not parented then
        if _typeof(gethui) == "function" then
            local ok = _pcall(function() screenGui.Parent = gethui() end)
            parented = ok and screenGui.Parent ~= nil
        end
    end
    if not parented and _typeof(syn) == "table" and _typeof(syn.protect_gui) == "function" then
        local ok = _pcall(function()
            syn.protect_gui(screenGui)
            screenGui.Parent = CoreGui
        end)
        parented = ok and screenGui.Parent ~= nil
    end
    if not parented then
        local ok = _pcall(function() screenGui.Parent = CoreGui end)
        parented = ok and screenGui.Parent ~= nil
    end
    if not parented then
        screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    end

    -- Create decoys and start name rotation
    AntiDex.createDecoys(nil, _mrand(5, 10))
    local protectedInstances = {screenGui}

    self.ScreenGui = screenGui

    screenGui:GetPropertyChangedSignal("DisplayOrder"):Connect(function()
        if screenGui.DisplayOrder ~= 2147483647 then
            screenGui.DisplayOrder = 2147483647
        end
    end)

    local mainFrame = Instance.new("Frame")
    mainFrame.Size = UDim2.new(0, windowSize.X, 0, windowSize.Y)
    mainFrame.Position = UDim2.new(0.5, -windowSize.X / 2, 0.5, -windowSize.Y / 2)
    mainFrame.BackgroundColor3 = THEME.BgColor
    mainFrame.BorderSizePixel = 0
    mainFrame.Visible = false
    mainFrame.Active = true
    mainFrame.ZIndex = 2
    mainFrame.ClipsDescendants = true
    mainFrame.Parent = screenGui

    local windowScale = Instance.new("UIScale")
    windowScale.Scale = 1
    windowScale.Parent = mainFrame

    Instance.new("UICorner", mainFrame).CornerRadius = UDim.new(0, CORNER_RADIUS)

    local mainStroke = Instance.new("UIStroke")
    mainStroke.Color = THEME.DividerColor
    mainStroke.Thickness = 1
    mainStroke.Parent = mainFrame

    _tinsert(protectedInstances, mainFrame)
    AntiDex.protect(mainFrame)

    local headerH = IS_MOBILE and 46 or 42
    local header = Instance.new("Frame")
    header.Size = UDim2.new(1, 0, 0, headerH)
    header.BackgroundColor3 = THEME.ContainerColor
    header.BorderSizePixel = 0
    header.Active = true
    header.Parent = mainFrame

    Instance.new("UICorner", header).CornerRadius = UDim.new(0, CORNER_RADIUS)

    local headerBottomMask = Instance.new("Frame")
    headerBottomMask.Size = UDim2.new(1, 0, 0, CORNER_RADIUS)
    headerBottomMask.Position = UDim2.new(0, 0, 1, -CORNER_RADIUS)
    headerBottomMask.BackgroundColor3 = THEME.ContainerColor
    headerBottomMask.BorderSizePixel = 0
    headerBottomMask.Parent = header

    -- Avatar
    local avatarSize = headerH - 16
    local avatarHolder = Instance.new("Frame")
    avatarHolder.Size = UDim2.new(0, avatarSize, 0, avatarSize)
    avatarHolder.Position = UDim2.new(0, 10, 0.5, -avatarSize / 2)
    avatarHolder.BackgroundTransparency = 1
    avatarHolder.Visible = false
    avatarHolder.Parent = header

    local avatarBuilt = false
    local function setAvatarEnabled(enabled)
        if enabled and not avatarBuilt then
            avatarBuilt = true
            _spawn(buildAvatar, avatarHolder, avatarSize)
        end
        avatarHolder.Visible = enabled
    end

    -- Title
    local titleLabel = Instance.new("TextLabel")
    titleLabel.AutomaticSize = Enum.AutomaticSize.X
    titleLabel.Size = UDim2.new(0, 0, 1, 0)
    titleLabel.Position = UDim2.new(0, 14, 0, 0)
    titleLabel.Text = title
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = 15
    titleLabel.TextColor3 = THEME.TextColor
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.BackgroundTransparency = 1
    titleLabel.Parent = header

    local function updateTitleOffset()
        titleLabel.Position = UDim2.new(0, avatarHolder.Visible and (avatarSize + 18) or 14, 0, 0)
    end
    avatarHolder:GetPropertyChangedSignal("Visible"):Connect(updateTitleOffset)

    -- Header line
    local headerLine = Instance.new("Frame")
    headerLine.Size = UDim2.new(1, 0, 0, 1)
    headerLine.Position = UDim2.new(0, 0, 1, 0)
    headerLine.BackgroundColor3 = THEME.DividerColor
    headerLine.BorderSizePixel = 0
    headerLine.Parent = header

    -- ===== CLOSE BUTTON (Method 1) =====
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, headerH - 14, 0, headerH - 14)
    closeBtn.Position = UDim2.new(1, -(headerH - 7), 0.5, -(headerH - 14) / 2)
    closeBtn.BackgroundColor3 = THEME.DividerColor
    closeBtn.Text = ""
    closeBtn.AutoButtonColor = false
    closeBtn.Visible = (hideMethod == 1)
    closeBtn.Parent = header
    Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(1, 0)
    drawCross(closeBtn, 12, THEME.TextColor, 2)
    attachPressEffect(closeBtn, 1.08)

    -- ===== SIDEBAR =====
    local sidebarW = IS_MOBILE and _mmax(96, _mfloor(windowSize.X * 0.26)) or 120

    local sidebarHolder = Instance.new("Frame")
    sidebarHolder.Size = UDim2.new(0, sidebarW, 1, -(headerH + 1))
    sidebarHolder.Position = UDim2.new(0, 0, 0, headerH + 1)
    sidebarHolder.BackgroundColor3 = THEME.SidebarColor
    sidebarHolder.BorderSizePixel = 0
    sidebarHolder.Parent = mainFrame

    Instance.new("UICorner", sidebarHolder).CornerRadius = UDim.new(0, CORNER_RADIUS)

    local sidebarMaskTop = Instance.new("Frame")
    sidebarMaskTop.Size = UDim2.new(1, 0, 0, CORNER_RADIUS)
    sidebarMaskTop.BackgroundColor3 = THEME.SidebarColor
    sidebarMaskTop.BorderSizePixel = 0
    sidebarMaskTop.Parent = sidebarHolder

    local sidebarMaskRight = Instance.new("Frame")
    sidebarMaskRight.Size = UDim2.new(0, CORNER_RADIUS, 1, 0)
    sidebarMaskRight.Position = UDim2.new(1, -CORNER_RADIUS, 0, 0)
    sidebarMaskRight.BackgroundColor3 = THEME.SidebarColor
    sidebarMaskRight.BorderSizePixel = 0
    sidebarMaskRight.Parent = sidebarHolder

    local sidebar = Instance.new("ScrollingFrame")
    sidebar.Size = UDim2.new(1, 0, 1, -CORNER_RADIUS)
    sidebar.BackgroundTransparency = 1
    sidebar.BorderSizePixel = 0
    sidebar.ScrollBarThickness = 0
    sidebar.ScrollingDirection = Enum.ScrollingDirection.Y
    sidebar.ElasticBehavior = Enum.ElasticBehavior.WhenScrollable
    sidebar.CanvasSize = UDim2.new(0, 0, 0, 0)
    sidebar.AutomaticCanvasSize = Enum.AutomaticSize.Y
    sidebar.Active = true
    sidebar.Parent = sidebarHolder

    local sidebarLayout = Instance.new("UIListLayout")
    sidebarLayout.Padding = UDim.new(0, 4)
    sidebarLayout.SortOrder = Enum.SortOrder.LayoutOrder
    sidebarLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    sidebarLayout.Parent = sidebar

    local sidebarPadding = Instance.new("UIPadding")
    sidebarPadding.PaddingTop = UDim.new(0, 8)
    sidebarPadding.PaddingBottom = UDim.new(0, 8)
    sidebarPadding.Parent = sidebar

    -- Content
    local contentFrame = Instance.new("Frame")
    contentFrame.Size = UDim2.new(1, -(sidebarW + 6 + CORNER_RADIUS), 1, -(headerH + 7 + CORNER_RADIUS))
    contentFrame.Position = UDim2.new(0, sidebarW + 6, 0, headerH + 7)
    contentFrame.BackgroundTransparency = 1
    contentFrame.Parent = mainFrame

    self.MainFrame = mainFrame
    self.Sidebar = sidebar
    self.SidebarWidth = sidebarW
    self.ContentFrame = contentFrame
    self.Tabs = {}
    self.TabOrder = 0
    self.CurrentTab = nil
    self.IsOpen = false
    self.Destroyed = false
    self.HideMethod = hideMethod

    -- ===== BOTTOM LINE (Method 2) =====
    local bottomLine, bottomLineFill

    if true then -- Always create, visibility controlled by method
        bottomLine = Instance.new("Frame")
        bottomLine.Size = UDim2.new(1, -20, 0, 4)
        bottomLine.Position = UDim2.new(0, 10, 1, -8)
        bottomLine.BackgroundColor3 = THEME.DividerColor
        bottomLine.BorderSizePixel = 0
        bottomLine.ClipsDescendants = true
        bottomLine.Visible = (hideMethod == 2)
        bottomLine.ZIndex = 10
        bottomLine.Parent = mainFrame
        Instance.new("UICorner", bottomLine).CornerRadius = UDim.new(1, 0)

        bottomLineFill = Instance.new("Frame")
        bottomLineFill.Size = UDim2.new(0, 0, 1, 0)
        bottomLineFill.Position = UDim2.fromScale(0, 0)
        bottomLineFill.BackgroundColor3 = THEME.LineActiveColor
        bottomLineFill.BorderSizePixel = 0
        bottomLineFill.Parent = bottomLine
        Instance.new("UICorner", bottomLineFill).CornerRadius = UDim.new(1, 0)
    end

    -- ===== CIRCLE BUTTON (Method 4) =====
    local circleBtn
    do
        local cSize = IS_MOBILE and 50 or 44
        circleBtn = Instance.new("TextButton")
        circleBtn.Size = UDim2.new(0, cSize, 0, cSize)
        circleBtn.Position = UDim2.new(0, 16, 0.5, 0)
        circleBtn.AnchorPoint = Vector2.new(0, 0.5)
        circleBtn.BackgroundColor3 = THEME.ContainerColor
        circleBtn.Text = ""
        circleBtn.AutoButtonColor = false
        circleBtn.Visible = (hideMethod == 4)
        circleBtn.ZIndex = 15
        circleBtn.Parent = screenGui
        Instance.new("UICorner", circleBtn).CornerRadius = UDim.new(1, 0)
        local cStroke = Instance.new("UIStroke")
        cStroke.Color = THEME.DividerColor
        cStroke.Thickness = 1
        cStroke.Parent = circleBtn
        drawBurger(circleBtn, 18, THEME.TextColor)
        attachPressEffect(circleBtn, 1.1)
        _tinsert(protectedInstances, circleBtn)
        AntiDex.protect(circleBtn)

        -- Make draggable
        circleBtn.InputBegan:Connect(function(input)
            if not isTouchOrMouse(input) then return end
            local startInputPos = input.Position
            local startBtnPos = circleBtn.Position
            local moved = false
            local moveConn
            moveConn = UserInputService.InputChanged:Connect(function(changed)
                if changed ~= input and not (input.UserInputType == Enum.UserInputType.MouseButton1 and changed.UserInputType == Enum.UserInputType.MouseMovement) then return end
                local delta = changed.Position - startInputPos
                if delta.Magnitude > 8 then moved = true end
                if moved then
                    local vp2 = Workspace.CurrentCamera and Workspace.CurrentCamera.ViewportSize or Vector2.new(800, 600)
                    local newX = _mclamp(startBtnPos.X.Offset + delta.X, 4, vp2.X - cSize - 4)
                    local newY = _mclamp(startBtnPos.Y.Scale * vp2.Y + startBtnPos.Y.Offset + delta.Y, 4, vp2.Y - cSize - 4)
                    circleBtn.Position = UDim2.new(0, newX, 0, newY)
                end
            end)
            watchInputEnd(input, function()
                moveConn:Disconnect()
                if not moved then
                    -- Toggle menu
                    if self.IsOpen then
                        self:SetOpen(false)
                    else
                        self:SetOpen(true)
                    end
                end
            end)
        end)
    end

    -- ===== BUBBLE BUTTON (Methods 1, 2, 3 — for reopening) =====
    local bubbleSize = IS_MOBILE and 52 or 44
    local bubble = Instance.new("TextButton")
    bubble.Size = UDim2.new(0, bubbleSize, 0, bubbleSize)
    bubble.Position = UDim2.new(1, -bubbleSize - 12, 0, 70)
    bubble.BackgroundColor3 = THEME.ContainerColor
    bubble.Text = ""
    bubble.AutoButtonColor = false
    bubble.Visible = false
    bubble.ZIndex = 15
    bubble.Parent = screenGui
    Instance.new("UICorner", bubble).CornerRadius = UDim.new(1, 0)
    local bubbleStroke = Instance.new("UIStroke")
    bubbleStroke.Color = THEME.DividerColor
    bubbleStroke.Thickness = 1
    bubbleStroke.Parent = bubble
    drawBurger(bubble, 18, THEME.TextColor)
    attachPressEffect(bubble, 1.1)
    _tinsert(protectedInstances, bubble)
    AntiDex.protect(bubble)

    -- Bubble drag + tap
    bubble.InputBegan:Connect(function(input)
        if not isTouchOrMouse(input) then return end
        local startInputPos = input.Position
        local startBubblePos = bubble.Position
        local moved = false
        local moveConn
        moveConn = UserInputService.InputChanged:Connect(function(changed)
            if changed ~= input and not (input.UserInputType == Enum.UserInputType.MouseButton1 and changed.UserInputType == Enum.UserInputType.MouseMovement) then return end
            local delta = changed.Position - startInputPos
            if delta.Magnitude > 8 then moved = true end
            if moved then
                local vp2 = Workspace.CurrentCamera and Workspace.CurrentCamera.ViewportSize or Vector2.new(800, 600)
                local newX = _mclamp(startBubblePos.X.Scale * vp2.X + startBubblePos.X.Offset + delta.X, 4, vp2.X - bubbleSize - 4)
                local newY = _mclamp(startBubblePos.Y.Scale * vp2.Y + startBubblePos.Y.Offset + delta.Y, 4, vp2.Y - bubbleSize - 4)
                bubble.Position = UDim2.new(0, newX, 0, newY)
            end
        end)
        watchInputEnd(input, function()
            moveConn:Disconnect()
            if not moved then
                self:SetOpen(true)
            end
        end)
    end)

    -- ===== OPEN / CLOSE LOGIC =====
    function self:SetOpen(open)
        if self.Destroyed then return end
        if open == self.IsOpen then return end
        self.IsOpen = open

        if open then
            -- === SHOW ===
            if self.HideMethod == 4 then
                -- Circle button stays visible
            else
                -- Hide bubble
                bubble.Visible = false
            end

            if self.HideMethod == 1 then
                -- Wave show from top center
                WaveAnim.show(mainFrame, windowScale, 0.5, 0, 0.4)
            elseif self.HideMethod == 2 then
                -- Normal show + fill bottom line
                mainFrame.Visible = true
                windowScale.Scale = 0.92
                createTween(windowScale, TweenInfo.new(0.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Scale = 1 })
                -- Fill animation
                bottomLine.Visible = true
                bottomLineFill.Size = UDim2.new(0, 0, 1, 0)
                BezierEngine.tween(bottomLineFill, {
                    Size = UDim2.new(1, 0, 1, 0),
                }, 0.6, "EaseOutExpo")
            elseif self.HideMethod == 3 then
                -- Wave show from center
                WaveAnim.show(mainFrame, windowScale, 0.5, 0.5, 0.4)
            elseif self.HideMethod == 4 then
                -- Wave show from left center (where circle button is)
                WaveAnim.show(mainFrame, windowScale, 0, 0.5, 0.4)
            end
        else
            -- === HIDE ===
            if self.HideMethod == 1 then
                -- Wave hide to top center
                WaveAnim.hide(mainFrame, windowScale, 0.5, 0, 0.4, function()
                    bubble.Visible = true
                end)
            elseif self.HideMethod == 2 then
                -- Drain bottom line, then hide
                BezierEngine.tween(bottomLineFill, {
                    Size = UDim2.new(0, 0, 1, 0),
                }, 0.4, "EaseInExpo", function()
                    createTween(windowScale, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.In), { Scale = 0.92 }).Completed:Connect(function()
                        if not self.IsOpen then
                            mainFrame.Visible = false
                            bubble.Visible = true
                        end
                    end)
                end)
            elseif self.HideMethod == 3 then
                -- Wave hide to center (where title was tapped)
                WaveAnim.hide(mainFrame, windowScale, 0.5, 0.1, 0.4, function()
                    -- Method 3: no bubble, double-tap to reopen
                end)
            elseif self.HideMethod == 4 then
                -- Wave hide to left center
                WaveAnim.hide(mainFrame, windowScale, 0, 0.5, 0.4)
            end
        end
    end

    function self:UpdateHideMethod(method)
        self.HideMethod = method
        settingsCache:Set("HideMethod", method)

        -- Update visibility of controls
        closeBtn.Visible = (method == 1)
        bottomLine.Visible = (method == 2)
        circleBtn.Visible = (method == 4)

        -- Bubble is shown when menu is closed (except method 3 and 4)
        if not self.IsOpen then
            bubble.Visible = (method ~= 3 and method ~= 4)
        end
    end

    -- Method 1: Close button click
    closeBtn.Activated:Connect(function()
        if self.HideMethod == 1 then
            self:SetOpen(false)
        end
    end)

    -- Method 3: Tap on title text to hide
    titleLabel.InputBegan:Connect(function(input)
        if self.HideMethod ~= 3 then return end
        if not isTouchOrMouse(input) then return end
        local startPos = input.Position
        local startTime = os.clock()
        watchInputEnd(input, function()
            local dist = (input.Position - startPos).Magnitude
            if (os.clock() - startTime) < 0.3 and dist < 10 then
                self:SetOpen(false)
            end
        end)
    end)

    -- Method 3: Double-tap center of screen to open
    local lastTapTime = 0
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed or self.IsOpen or self.Destroyed then return end
        if self.HideMethod ~= 3 then return end -- Only for method 3
        if isTouchOrMouse(input) then
            local cam = Workspace.CurrentCamera
            if not cam then return end
            local screenCenter = cam.ViewportSize / 2
            local inputPos = Vector2.new(input.Position.X, input.Position.Y)
            if (inputPos - screenCenter).Magnitude <= 160 then
                local currentTime = os.clock()
                if currentTime - lastTapTime <= 0.35 then
                    self:SetOpen(true)
                end
                lastTapTime = currentTime
            end
        end
    end)

    -- Drag header
    local dragInput = nil
    header.InputBegan:Connect(function(input)
        if not isTouchOrMouse(input) then return end
        if dragInput then return end
        dragInput = input
        local dragStart = input.Position
        local startPos = mainFrame.Position
        local moveConn
        moveConn = UserInputService.InputChanged:Connect(function(changed)
            if changed ~= input and not (input.UserInputType == Enum.UserInputType.MouseButton1 and changed.UserInputType == Enum.UserInputType.MouseMovement) then return end
            local delta = changed.Position - dragStart
            local vp2 = Workspace.CurrentCamera and Workspace.CurrentCamera.ViewportSize or Vector2.new(800, 600)
            local newX = _mclamp(startPos.X.Scale * vp2.X + startPos.X.Offset + delta.X, -windowSize.X + 60, vp2.X - 60)
            local newY = _mclamp(startPos.Y.Scale * vp2.Y + startPos.Y.Offset + delta.Y, 0, vp2.Y - headerH)
            mainFrame.Position = UDim2.new(0, newX, 0, newY)
        end)
        watchInputEnd(input, function()
            moveConn:Disconnect()
            dragInput = nil
        end)
    end)

    function self:Destroy()
        if self.Destroyed then return end
        self.Destroyed = true
        createTween(windowScale, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), { Scale = 0.85 }).Completed:Connect(function()
            screenGui:Destroy()
        end)
        _pcall(function() bubble:Destroy() end)
        _pcall(function() circleBtn:Destroy() end)
    end

    -- Notifications (сохраняю твою систему)
    local notifyHolder = Instance.new("Frame")
    notifyHolder.Size = UDim2.new(0, 240, 1, -20)
    notifyHolder.Position = UDim2.new(1, -250, 0, 10)
    notifyHolder.BackgroundTransparency = 1
    notifyHolder.Parent = screenGui
    local notifyLayout = Instance.new("UIListLayout")
    notifyLayout.Padding = UDim.new(0, 6)
