    -- ==================== VIEWPORT (full-body avatar display) ====================
    function TabClass:Viewport(opts)
        opts = opts or {}
        local height = opts.Height or 150
        self._lastRow = nil

        local item = Instance.new("Frame")
        item.Size = UDim2.new(1, 0, 0, height)
        item.BackgroundColor3 = THEME.ContainerColor
        item.ClipsDescendants = true
        item.Parent = self.Container
        storeOrigSize(item, 0)
        Instance.new("UICorner", item).CornerRadius = UDim.new(0, 8)

        local vp = Instance.new("ViewportFrame")
        vp.Size = UDim2.new(1, 0, 1, 0)
        vp.BackgroundTransparency = 1
        vp.Parent = item
        Instance.new("UICorner", vp).CornerRadius = UDim.new(0, 8)

        _spawn(function()
            local player = LocalPlayer
            local char = player.Character or player.CharacterAdded:Wait()
            _wait(1) -- Wait for clothing to load

            _pcall(function()
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if not humanoid then return end

                local description = humanoid:GetAppliedDescription()
                local clone = Players:CreateHumanoidModelFromDescription(description, humanoid.RigType)

                for _, obj in clone:GetDescendants() do
                    if obj:IsA("BaseScript") or obj:IsA("Animator")
                        or obj:IsA("Animation") or obj:IsA("Sound") then
                        obj:Destroy()
                    end
                end

                local hrp = clone:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.Anchored = true
                    hrp.CFrame = CFrame.new(0, 0, 0)
                end

                local cloneHum = clone:FindFirstChildOfClass("Humanoid")
                if cloneHum then cloneHum:Destroy() end

                clone.Parent = vp

                local cam = Instance.new("Camera")
                cam.Parent = vp
                vp.CurrentCamera = cam
                cam.CFrame = CFrame.new(Vector3.new(0, 2, -5.5), Vector3.new(0, 1.5, 0))

                -- Slow rotation
                local angle = 0
                RunService.RenderStepped:Connect(function(dt)
                    if vp.Parent and hrp and hrp.Parent then
                        angle = angle + dt * 0.4
                        _pcall(function()
                            hrp.CFrame = CFrame.new(0, 0, 0) * CFrame.Angles(0, angle, 0)
                        end)
                    end
                end)
            end)
        end)

        return vp
    end

    -- ============================================================
    -- SECTION 14: SETTINGS TAB (built-in, always last)
    -- ============================================================

    _defer(function()
        local settingsTab = self:CreateTab("Settings")
        settingsTab.Button.LayoutOrder = 9999

        settingsTab:Section("Interface")

        -- Hide method dropdown
        local hideMethodNames = {
            [1] = "Крестик + волна вверх",
            [2] = "Нижняя линия",
            [3] = "Двойной тап + заголовок",
            [4] = "Круглая кнопка",
        }
        local hideOptions = {}
        local currentHideName = hideMethodNames[self.HideMethod] or hideMethodNames[1]
        for i = 1, 4 do _tinsert(hideOptions, hideMethodNames[i]) end

        settingsTab:Dropdown("Скрытие меню", hideOptions, currentHideName, function(option)
            for idx, name in hideMethodNames do
                if name == option then
                    self:UpdateHideMethod(idx)
                    if idx == 3 then
                        self:Notify("Двойной тап по центру экрана = открыть\nТап по заголовку = скрыть", 4)
                    elseif idx == 4 then
                        self:Notify("Круглая кнопка слева — открыть/скрыть", 3)
                    end
                    break
                end
            end
        end)

        -- Animation curve preset
        settingsTab:Section("Animations")

        local curveNames = BezierEngine.getPresetNames()
        settingsTab:Dropdown("Кривая анимации", curveNames, currentAnimCurve, function(option)
            currentAnimCurve = option
            settingsCache:Set("AnimCurve", option)
        end)

        settingsTab:Slider("Скорость анимации", 0.2, 2.0, animSpeedMultiplier, function(val)
            animSpeedMultiplier = val
            settingsCache:Set("AnimSpeed", val)
        end)

        settingsTab:Section("Display")

        settingsTab:Toggle("Аватар в шапке", settingsCache:Get("Avatar", false), function(state)
            self._setAvatarEnabled(state)
            settingsCache:Set("Avatar", state)
        end)

        settingsTab:Section("Checkbox")

        local checkboxDemo
        local checkboxSizeSlider

        checkboxDemo = settingsTab:Checkbox("Пример чекбокса", false, function(state)
            -- demo
        end, { CheckSize = settingsCache:Get("CheckSize", 18) })

        checkboxSizeSlider = settingsTab:Slider("Размер чекбокса", 12, 36, settingsCache:Get("CheckSize", 18), function(val)
            local rounded = _mfloor(val)
            settingsCache:Set("CheckSize", rounded)
            checkboxDemo:SetSize(rounded)
        end)

        settingsTab:Section("Preview")

        settingsTab:Viewport({ Height = 160 })

        settingsTab:Section("Danger zone")

        local rowH = IS_MOBILE and 44 or 38
        local exitRow = Instance.new("Frame")
        exitRow.Size = UDim2.new(1, 0, 0, rowH)
        exitRow.BackgroundTransparency = 1
        exitRow.Parent = settingsTab.Container
        storeOrigSize(exitRow, 1)

        local confirming = false

        local cancelBtn = Instance.new("TextButton")
        cancelBtn.Size = UDim2.new(1, 0, 1, 0)
        cancelBtn.BackgroundColor3 = THEME.DangerColor
        cancelBtn.Text = "Выйти"
        cancelBtn.Font = Enum.Font.GothamBold
        cancelBtn.TextSize = 14
        cancelBtn.TextColor3 = THEME.TextColor
        cancelBtn.AutoButtonColor = false
        cancelBtn.Parent = exitRow
        Instance.new("UICorner", cancelBtn).CornerRadius = UDim.new(0, 8)

        local confirmBtn = Instance.new("TextButton")
        confirmBtn.Size = UDim2.new(0, 0, 1, 0)
        confirmBtn.Position = UDim2.new(1, 0, 0, 0)
        confirmBtn.AnchorPoint = Vector2.new(1, 0)
        confirmBtn.BackgroundColor3 = THEME.DangerColor
        confirmBtn.Text = ""
        confirmBtn.Font = Enum.Font.GothamBold
        confirmBtn.TextSize = 14
        confirmBtn.TextColor3 = THEME.TextColor
        confirmBtn.AutoButtonColor = false
        confirmBtn.Visible = false
        confirmBtn.Parent = exitRow
        Instance.new("UICorner", confirmBtn).CornerRadius = UDim.new(0, 8)

        attachPressEffect(cancelBtn, 1.02)
        attachPressEffect(confirmBtn, 1.02)

        local function enterConfirm()
            confirming = true
            cancelBtn.Text = "Отменить"
            createTween(cancelBtn, T_FAST, {
                Size = UDim2.new(0.5, -3, 1, 0),
                BackgroundColor3 = THEME.DividerColor,
            })
            confirmBtn.Visible = true
            confirmBtn.Text = "Выйти"
            createTween(confirmBtn, T_FAST, { Size = UDim2.new(0.5, -3, 1, 0) })
        end

        local function exitConfirm()
            confirming = false
            cancelBtn.Text = "Выйти"
            createTween(cancelBtn, T_FAST, {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundColor3 = THEME.DangerColor,
            })
            createTween(confirmBtn, T_FAST, { Size = UDim2.new(0, 0, 1, 0) }).Completed:Connect(function()
                if not confirming then confirmBtn.Visible = false end
            end)
        end

        cancelBtn.Activated:Connect(function()
            if confirming then exitConfirm() else enterConfirm() end
        end)

        confirmBtn.Activated:Connect(function()
            if confirming then self:Destroy() end
        end)

        -- Load saved settings
        self:UpdateHideMethod(self.HideMethod)

        local savedCurve = settingsCache:Get("AnimCurve")
        if savedCurve then currentAnimCurve = savedCurve end

        local savedSpeed = settingsCache:Get("AnimSpeed")
        if savedSpeed then animSpeedMultiplier = savedSpeed end

        if settingsCache:Get("Avatar", false) then
            self._setAvatarEnabled(true)
        end
    end)

    return self
end

return iOSLibrary
