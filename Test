local function normalizeGithubUrl(url)
    if url:find("github%.com") and url:find("/blob/") then
        url = url:gsub("github%.com", "raw.githubusercontent.com"):gsub("/blob/", "/")
    end
    return url
end

local function httpGet(url)
    local ok, res = _pcall(function() return game:HttpGet(url) end)
    if ok and res then return res end
    local req = (_typeof(syn) == "table" and syn.request) or http_request or request
    if req then
        local ok2, res2 = _pcall(function() return req({ Url = url, Method = "GET" }) end)
        if ok2 and res2 and res2.Body then return res2.Body end
    end
    return nil
end

local imageCache = {}
local function fetchImage(url)
    url = normalizeGithubUrl(url)
    if imageCache[url] then return imageCache[url] end
    if not (HAS_FS and _typeof(getcustomasset) == "function") then return nil end
    local fileName = CACHE_FOLDER .. "/img_" .. url:gsub("[^%w]", ""):sub(-40) .. ".png"
    local ok, asset = _pcall(function()
        if not isfile(fileName) then
            local data = httpGet(url)
            if not data then error("no data") end
            writefile(fileName, data)
        end
        return getcustomasset(fileName)
    end)
    if ok and asset then imageCache[url] = asset; return asset end
    return nil
end

