        box.AnchorPoint = Vector2.new(0, 0.5)
        box.BackgroundColor3 = state and THEME.ToggleOnColor or THEME.DividerColor
        box.BorderSizePixel = 0
        box.Parent = itemFrame
        Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4)

        local boxStroke = Instance.new("UIStroke")
        boxStroke.Color = THEME.DividerColor
        boxStroke.Thickness = 1
        boxStroke.Parent = box

        local checkmark = Instance.new("TextLabel")
        checkmark.Size = UDim2.fromScale(1, 1)
        checkmark.BackgroundTransparency = 1
        checkmark.Text = state and "✓" or ""
        checkmark.TextColor3 = Color3.fromRGB(255, 255, 255)
        checkmark.TextSize = _mfloor(checkSize * 0.65)
        checkmark.Font = Enum.Font.GothamBold
        checkmark.Parent = box

        local textLabel = Instance.new("TextLabel")
        textLabel.Size = UDim2.new(1, -(checkSize + 30), 1, 0)
        textLabel.Position = UDim2.fromOffset(checkSize + 22, 0)
        textLabel.BackgroundTransparency = 1
        textLabel.Text = label
        textLabel.TextColor3 = THEME.TextColor
        textLabel.TextSize = 13
        textLabel.Font = THEME.Font
        textLabel.TextXAlignment = Enum.TextXAlignment.Left
        textLabel.TextTruncate = Enum.TextTruncate.AtEnd
        textLabel.Parent = itemFrame

        attachPressEffect(itemFrame, 1.02)

        local function updateVisual()
            createTween(box, T_FAST, {
                BackgroundColor3 = state and THEME.ToggleOnColor or THEME.DividerColor,
            })
            if state then
                checkmark.Text = "✓"
                -- Pop effect
                local boxScale = box:FindFirstChildOfClass("UIScale")
                if not boxScale then
                    boxScale = Instance.new("UIScale")
                    boxScale.Parent = box
                end
                boxScale.Scale = 0.8
                createTween(boxScale, T_RELEASE, { Scale = 1 })
            else
                checkmark.Text = ""
            end
        end

        itemFrame.Activated:Connect(function()
            state = not state
            updateVisual()
            _spawn(callback, state)
        end)

        local api = {}
        function api:Set(val) state = val; updateVisual(); _spawn(callback, state) end
        function api:Get() return state end
        function api:SetSize(newSize)
            checkSize = newSize
            box.Size = UDim2.fromOffset(checkSize, checkSize)
            checkmark.TextSize = _mfloor(checkSize * 0.65)
            textLabel.Size = UDim2.new(1, -(checkSize + 30), 1, 0)
            textLabel.Position = UDim2.fromOffset(checkSize + 22, 0)
        end
        return api
    end

